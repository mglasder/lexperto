# Required: choose one provider path.
LLM_MODEL=openai:gpt-4.1-mini

# Optional drafting model override (defaults to LLM_MODEL when unset)
SACHVERHALT_DRAFT_MODEL=
# Example: openai:gpt-4.1-mini or anthropic:claude-3-7-sonnet-latest

# OpenAI path (required if LLM_MODEL=openai:...)
OPENAI_API_KEY=

# Claude path (required if LLM_MODEL=anthropic:...)
ANTHROPIC_API_KEY=

# Optional: enable LangSmith prompt pulling/tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Optional: local prompt overrides
EXTRACTION_PROMPT_PATH=
PARSING_PROMPT_PATH=
PARAGRAPHS_PROMPT_PATH=
ANNOTATION_PROMPT_PATH=
